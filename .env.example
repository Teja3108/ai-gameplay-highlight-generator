# Compose / development convenience
APP_ENV=development
API_PORT=8000
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api

# API runtime (loaded by EnvironmentConfigProvider)
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/gameplay.db
STORAGE_ROOT=.local-storage
TEMP_DIRECTORY=./data/tmp
GPU_PREFERENCE=auto
MODEL_CACHE_PATH=./data/models
OUTPUT_DIRECTORY=./data/output

# Web/API boundary (keep these local unless an authenticated deployment is added)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1
MAX_UPLOAD_BYTES=107374182400
MAX_CONCURRENT_JOBS=1

# Existing local AI engine bridge
GAMEPLAY_ENGINE_ROOT=/absolute/path/to/AI-Youtube-Shorts-Generator
GAMEPLAY_ENGINE_PYTHON=/absolute/path/to/AI-Youtube-Shorts-Generator/.venv/bin/python
GAMEPLAY_ENGINE_OUTPUT_DIR=/absolute/path/to/AI-Youtube-Shorts-Generator/output

# Gemini reliability (used by the existing local AI engine when LLM_PROVIDER=gemini)
# GEMINI_API_KEYS takes precedence and accepts a comma-separated key list; never commit real keys.
GEMINI_API_KEYS=
GEMINI_MAX_RETRIES=5
GEMINI_RETRY_DELAYS=5,10,20,40,60
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-1.5-flash
GEMINI_MODEL_FALLBACK_ENABLED=true
GEMINI_KEY_ROTATION_ENABLED=true
